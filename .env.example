# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GitHub OAuth ────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3101/auth/github/callback

# ─── Groq (Chat / Generation) ────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─── OpenAI (Embeddings) ─────────────────────────────────────────────────────────
# Used for generating code_chunks embeddings (text-embedding-3-small → 1536 dims)
OPENAI_API_KEY=your-openai-api-key

# ─── Frontend (Vite public vars) ────────────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_ to the browser bundle
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3101
